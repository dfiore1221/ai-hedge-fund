<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.dfiore.ai-hedge-fund.paper-fills</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>cd "/Users/davidfiore/Documents/Hedge Fund/current-ai-hedge-fund" &amp;&amp; mkdir -p reports/paper_fills &amp;&amp; day_of_week="$(date +%u)" &amp;&amp; time_hhmm="$(date +%H%M)" &amp;&amp; if [ "$day_of_week" -le 5 ] &amp;&amp; [ "$time_hhmm" -ge 0930 ] &amp;&amp; [ "$time_hhmm" -le 1605 ]; then .venv/bin/python main.py fills apply &gt;&gt; reports/paper_fills/automation.log 2&gt;&amp;1; fi</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/davidfiore/Documents/Hedge Fund/current-ai-hedge-fund</string>

  <key>StartInterval</key>
  <integer>300</integer>

  <key>StandardOutPath</key>
  <string>/Users/davidfiore/Documents/Hedge Fund/current-ai-hedge-fund/reports/paper_fills/launchd.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/davidfiore/Documents/Hedge Fund/current-ai-hedge-fund/reports/paper_fills/launchd.err.log</string>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
